GSTATION_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/gstation"
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3007"

# Ключ Kimi (api.kimi.com) — для агента-расчётчика и парсинга сканов.
MOONSHOT_API_KEY=""
# Workspace агента (где лежат .claude/skills + KNOWLEDGE).
KIMI_AGENT_WORKSPACE="/path/to/gidrostroy"

# Бэкенд агента-расчётчика: kimi (по умолчанию) | claude.
# claude — считать через Claude Code CLI (например, когда квота Kimi 403).
# Инструменты агента ограничены allowlist в claude-agent.ts (без Bash).
# CALC_AGENT=claude
# CLAUDE_BIN=claude

# Публичный доступ через ngrok (npm run tunnel).
NGROK_AUTHTOKEN=""
NGROK_DOMAIN="registrar-scheme-headsman.ngrok-free.dev"
