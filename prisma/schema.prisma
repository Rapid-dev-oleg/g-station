// Схема БД приложения g-station — расчёт пожарных насосных станций.
// «Расчётное дело» хранится JSONB-полем System.dossier (валидируется ajv).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("GSTATION_DATABASE_URL")
}

enum Role {
  // ADMIN — устаревшее (legacy), не используется; убрать отдельной миграцией.
  ADMIN
  DIRECTOR
  ENGINEER
  MANAGER
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  READY
  SENT
  WON
  LOST
}

enum SystemTypeStatus {
  READY
  PLANNED
}

enum SystemStatus {
  INPUT
  CALCULATED
  REVIEWED
  FINALIZED
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  // legacy-поле (не используется; роль теперь в Membership). Оставлено, чтобы
  // миграция была аддитивной (прод гоняет db push без --accept-data-loss).
  role         Role         @default(ENGINEER)
  // Платформенный супер-админ (НейроСофт) — вне воркспейсов, открывает /admin.
  isSuperAdmin Boolean      @default(false)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  memberships  Membership[]
  projects     Project[]
  systems      System[]     @relation("SystemEngineer")
  priceLists   PriceList[]
}

// Воркспейс = компания-арендатор. Мультитенантность: данные делятся по воркспейсу
// (изоляция арендуемых сущностей — следующий этап; пока введены воркспейсы и роли).
model Workspace {
  id          String       @id @default(cuid())
  name        String
  inn         String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  memberships Membership[]
  clients     Client[]
  projects    Project[]
  systems     System[]
  jobs        Job[]
}

// Участие пользователя в воркспейсе с ролью. Роль — на воркспейс (человек может
// состоять в нескольких компаниях с разными правами).
model Membership {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  role        Role      @default(ENGINEER)
  createdAt   DateTime  @default(now())

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Client {
  id          String    @id @default(cuid())
  shortName   String
  fullName    String?
  inn         String?
  contactName String?
  phone       String?
  email       String?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
  // Мультитенантность: воркспейс-владелец. nullable для аддитивной миграции;
  // в коде фактически обязателен (проставляется из активного воркспейса).
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  workspaceId String?

  @@index([shortName])
  @@index([workspaceId])
}

model Project {
  id         String        @id @default(cuid())
  name       String
  objectName String
  status     ProjectStatus @default(DRAFT)
  deadline   DateTime?
  client     Client        @relation(fields: [clientId], references: [id])
  clientId   String
  owner      User          @relation(fields: [ownerId], references: [id])
  ownerId    String
  systems    System[]
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  workspaceId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([workspaceId])
}

// Тип системы — справочник; логика типа в коде-модуле (контракт типа).
model SystemType {
  code        String           @id // 'fire' | 'water' | 'power'
  name        String
  description String?
  status      SystemTypeStatus @default(PLANNED)
  // Реестр типа станции (скил «ядро + модуль типа», перенесён в данные).
  // Управляет идентификацией и парсингом ТЗ — см. parse-document.ts.
  skillName   String? // скил расчёта, напр. 'pump-station-calc'
  typeModule  String? // модуль типа в скиле, напр. 'типы/пожарные.md'
  schemaRef   String? // схема расчётного дела, напр. 'расчётное-дело.schema.json'
  triggers    Json? // ключевые слова идентификации типа из ТЗ (string[])
  purposes    Json? // допустимые назначения станции этого типа (string[])
  components  Json? // что считать компонентом станции, а не системой (string[])
  systems      System[]
  schemas      TypeSchema[]
}

// Версионная схема ввода типа (field-spec) — «опросный лист как данные».
// Из fields рисуется динамическая форма ревью и формируется опросный лист для
// агента. Одна версия со status='active' — текущая (конструктор схем, Фаза 1).
model TypeSchema {
  id        String     @id @default(cuid())
  type      SystemType @relation(fields: [typeCode], references: [code], onDelete: Cascade)
  typeCode  String
  version   Int
  // Field[] (см. src/lib/schema/types.ts): key, label, dataType, unit, options,
  // required, default, hint, visibleIf, provenance, вложенные fields.
  fields    Json
  status    String     @default("draft") // draft | active | archived
  note      String?
  createdAt DateTime   @default(now())

  @@unique([typeCode, version])
  @@index([typeCode, status])
}

// Версии файла скила/методики (шаги, модуль типа, KNOWLEDGE). Снимок при каждом
// сохранении (ручном или через ИИ) — история + откат. Живой файл в workspace
// читает агент; версии хранят прошлые состояния. path — как в actions/skills.
model SkillFileVersion {
  id        String   @id @default(cuid())
  path      String
  version   Int
  content   String
  note      String? // «ручная правка» / «ИИ: …» / «исходная»
  createdAt DateTime @default(now())

  @@unique([path, version])
  @@index([path])
}

// Прогон расчётного конвейера «шаг = скил» (Фаза 3). Шаги исполняются
// последовательно в ОДНОЙ сессии агента (sessionId) — контекст между шагами
// сохраняется. steps хранит определения+результаты каждого шага; state —
// накопленное «расчётное дело». Гейты: между шагами status='paused'.
model PipelineRun {
  id          String   @id @default(cuid())
  systemId    String? // опц. привязка к System
  typeCode    String
  sessionId   String? // сессия агента для resume между шагами
  status      String   @default("running") // running | paused | done | error
  currentStep Int      @default(0)
  card        Json // входная карточка (из шага «Вход»)
  state       Json? // накопленный результат (расчётное дело)
  steps       Json // [{ key, label, status, output, at }]
  summary     Json? // структурная сводка (характеристики/состав/смета/шифр) — финальный проход
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([systemId])
  @@index([status])
}

// Система = одна насосная станция. dossier — расчётное дело целиком (JSONB).
model System {
  id          String       @id @default(cuid())
  name        String
  type        SystemType   @relation(fields: [typeCode], references: [code])
  typeCode    String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  engineer    User?        @relation("SystemEngineer", fields: [engineerId], references: [id])
  engineerId  String?
  status      SystemStatus @default(INPUT)
  dossier     Json // расчётное дело (Dossier), валидируется JSON Schema
  kimiCalc    Json? // кеш расчёта Kimi-агента (расчётное дело по скилу)
  kimiCalcHash String? // хеш карточки на момент расчёта — для инвалидации кеша
  approvedSnapshot Json? // замороженные утверждённые данные (для ТКП/сметы)
  totalCost   Float? // зеркало dossier для списков
  clientPrice Float?
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id])
  workspaceId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
  @@index([workspaceId])
}

// Глобальные настройки (одна запись).
model Settings {
  id             String   @id @default("singleton")
  companyName    String?
  companyInn     String?
  companyAddress String?
  companyPhone   String?
  companyEmail   String?
  defaultRateUsd Float?
  defaultRateCny Float?
  defaultMarkup  Float?
  aiModel        String? // выбранная модель OpenRouter для парсинга документов
  openrouterKey  String? // ключ OpenRouter API
  kimiKey        String? // ключ Kimi (api.kimi.com) для CLI-агента и парсинга сканов
  calcAgent      String? // бэкенд агента-расчётчика: 'kimi' (по умолч.) | 'claude'
  updatedAt      DateTime @updatedAt
}

// ── Каталог ──────────────────────────────────────────────────────────

model Manufacturer {
  id         String        @id @default(cuid())
  name       String        @unique
  note       String?
  items      CatalogItem[]
  priceLists PriceList[]
}

// Категория продукции — справочник, расширяемый данными.
model ProductCategory {
  code  String        @id // 'pumps' | 'panels' | 'collectors' | 'reservoirs' | 'works' | ...
  name  String
  items CatalogItem[]
}

// Запись об импорте прайса производителя.
model PriceList {
  id             String       @id @default(cuid())
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id])
  manufacturerId String
  title          String
  sourceFile     String
  currency       String
  priceDate      DateTime
  rowCount       Int
  importedAt     DateTime     @default(now())
  importedBy     User?        @relation(fields: [importedById], references: [id])
  importedById   String?
}

// Позиция каталога. Цена актуальная (без истории) — перезаписывается при импорте.
model CatalogItem {
  id             String          @id @default(cuid())
  manufacturer   Manufacturer    @relation(fields: [manufacturerId], references: [id])
  manufacturerId String
  category       ProductCategory @relation(fields: [categoryCode], references: [code])
  categoryCode   String
  sku            String
  name           String
  attributes     Json? // атрибуты под категорию (мощность/Q/H, шифр, объём…)
  price          Float?
  currency       String?
  priceDate      DateTime?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([manufacturerId, sku])
  @@index([categoryCode])
}

// Справочник нормативов (СП/ГОСТ).
// Нормативная база (библиотека). Версионируется; на нормы ссылаются шаги/поля
// через токен {{norm:code#anchor}}. content хранит извлечённые таблицы/формулы
// с якорями (чтобы инструкция тянула конкретное значение). Правка ГОСТа — здесь.
model Norm {
  id         String   @id @default(cuid())
  code       String   @unique // 'СП 8.13130.2020' — год в коде = версия
  version    String? // опц. отдельно (для отображения/группировки)
  status     String   @default("active") // active | superseded | draft
  title      String
  category   String
  summary    String?
  url        String?
  // { "<anchor>": {label, table?/formula?/value?} } — адресуемые куски нормы
  content    Json?
  supersedes String? // id прежней версии (замещённой)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([status])
}

// Декларативные правила расчёта (триггеры материала, карта аналогов,
// матрица класса насоса и т.п.). Формулы остаются в TS — здесь только
// условия выбора. Снапшот версии в Dossier = id записи.
model RuleConfig {
  id            String   @id @default(cuid())
  ruleId        String // '5.7-material', '3.9-A-pump-class', '3.10-brand-map', '2.5-margin', 'B1-markup'
  version       String // 'v1', 'v2', 'v3' — соответствует версиям из ANALYSIS/19
  payload       Json // тело правила (структура зависит от ruleId)
  effectiveFrom DateTime @default(now())
  notes         String?
  active        Boolean  @default(true)

  @@unique([ruleId, version])
  @@index([ruleId, active])
}

// Фоновая задача (парсинг ТЗ / расчёт станции). Выполняется в очереди на
// сервере, прогресс/результат пишутся в БД — UI поллит, задача переживает
// уход со страницы.
model Job {
  id         String    @id @default(cuid())
  type       String // 'parse' | 'calc'
  status     String    @default("queued") // queued | running | done | error
  progress   Int       @default(0) // 0..100
  message    String? // текущий шаг (человекочитаемо)
  label      String? // имя файла / системы для списка
  input      Json? // параметры задачи
  result     Json? // результат (ParsedDocument / KimiCalcData / redirect)
  error      String?
  projectId  String?
  systemId   String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  workspaceId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([workspaceId])
}
